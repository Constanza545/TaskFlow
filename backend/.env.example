# Puerto del servidor
PORT=4000

# Secreto para firmar los JWT (usa un valor largo y aleatorio en producción)
JWT_SECRET=cambia-este-valor-por-uno-seguro

# Tiempo de expiración del token
JWT_EXPIRES_IN=8h

# Ruta del archivo SQLite
DB_PATH=./data/taskflow.sqlite

# Origen permitido para CORS (frontend)
CORS_ORIGIN=http://localhost:5173

# Intervalo (ms) para refrescar precios de criptomonedas vía CoinGecko
CRYPTO_POLL_INTERVAL_MS=15000
